# Atlas Treasury OS — environment
# RPC endpoint (overrides config.json rpcUrl)
RPC_URL=https://api.mainnet-beta.solana.com

# Keypair files (JSON array or base58 secret key) — the agent signs ONLY with these
DEV_KEYFILE=./keys/dev.keyfile
COLLECTOR_KEYFILE=./keys/collector.keyfile
TREASURY_KEYFILE=./keys/treasury.keyfile

# Optional: LLM proposer / reporter (bounded — cannot sign or move funds)
OPENAI_API_KEY=

# Optional: X (Twitter) reporting
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
